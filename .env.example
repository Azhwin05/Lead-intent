# ============================================================
# ecom-lead-gen-system / .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Google Gemini ────────────────────────────────────────────
# Gemini is FREE. Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyBqfH0ZAIn51fPKOjeg81rCwhWmmPjFN4Q

# ── Apollo.io ─────────────────────────────────────────────────
# Contact enrichment. Get key at https://app.apollo.io/settings/integrations
# Free tier: 50 credits/month. Upgrade for more volume.
APOLLO_API_KEY=Mrnoii7cJ_o2HOijwH1Ljg

# ── Similarweb ────────────────────────────────────────────────
# Traffic data. Get key at https://developer.similarweb.com
# OPTIONAL — system will use heuristic estimates if not set.
SIMILARWEB_API_KEY=your_similarweb_api_key_here

# ── Airtable ──────────────────────────────────────────────────
# Storage for all leads. Create free workspace at https://airtable.com
# API key: https://airtable.com/account → API section
# Base ID: Open your base → Help → API Documentation → base ID in URL
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# ── Instantly.ai ──────────────────────────────────────────────
# Cold email sender. $37/mo plan required.
# API key: https://app.instantly.ai/app/settings/integrations
# Campaign ID: Create a campaign first, grab ID from URL
INSTANTLY_API_KEY=OTI5M2RkODAtZDNkZi00Mzc0LTgyZmYtMWMyMjJhMGEwMDQ1OlBwR1JGa0NrTnFsWg==
INSTANTLY_CAMPAIGN_ID=https://app.instantly.ai/share/campaign?id=2ef40a8c-ce64-40e3-95c2-f3ed31b98153

# ── Slack ─────────────────────────────────────────────────────
# Webhook for daily summaries + hot lead alerts.
# Create at https://api.slack.com/apps → Incoming Webhooks
